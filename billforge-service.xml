<service>
  <id>BillForge</id>
  <name>BillForge Invoice API</name>
  <description>BillForge Python FastAPI Service</description>
  <executable>C:\laragon\bin\python\python-3.10\python.exe</executable>
  <arguments>-m uvicorn main:app --host 0.0.0.0 --port 8006</arguments>
  <workingdirectory>C:\invoice\backend_invoice</workingdirectory>
  <logpath>C:\invoice\backend_invoice\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <onfailure action="restart" delay="3 sec"/>
  <onfailure action="restart" delay="10 sec"/>
</service>